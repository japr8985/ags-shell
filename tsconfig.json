{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "strict": true,
    "module": "ES2022",
    "target": "ES2020",
    "lib": ["ES2023"],
    "moduleResolution": "Bundler",
    // "checkJs": true,
    // "allowJs": true,
    "jsx": "react-jsx",
    "jsxImportSource": "ags/gtk4",
    "paths": {
      "ags/*": ["/usr/share/astal/gjs/gtk4/*"],
      "gi://AstalHyprland*": ["./@girs/astalhyprland-0.1"],
      "gi://Astal*": ["./@girs/astal-4.0"],
      "gi://Gtk*": ["./@girs/gtk-4.0"],
      "gi://Gdk*": ["./@girs/gdk-4.0"]
    },
    
  }
}
